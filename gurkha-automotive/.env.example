# =============================================================
# Supabase
# =============================================================
# Found in Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key is SECRET. Server-side only. Never expose to the browser.
# Used by API routes to manage bookings with elevated privileges.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================
# Resend (transactional email)
# =============================================================
# Found in https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# The "from" address must be on a domain you have verified in Resend.
RESEND_FROM_EMAIL="Gurkha Automotive <bookings@yourdomain.com>"

# Where new-booking notification emails are sent (the garage's inbox).
GARAGE_NOTIFICATION_EMAIL=info@yourdomain.com

# =============================================================
# App
# =============================================================
# Public site URL, used in email links. No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
